generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  businessName      String?
  businessEmail     String?
  businessPhone     String?
  businessAddress   String?
  logo              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  categories        Category[]
  consignmentVisits ConsignmentVisit[]
  customPrices      CustomPrice[]
  customers         Customer[]
  invoices          Invoice[]
  notifications     Notification[]
  products          Product[]
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  body      String
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())
  userId    String
  invoiceId String?
  productId String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id                String             @id @default(uuid())
  email             String
  phone             String?
  address           String?
  address2          String?
  city              String?
  county            String?
  postcode          String?
  paymentTerms      String             @default("net_30")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String
  companyName       String
  contactInfo       String?
  isConsignment     Boolean            @default(false)
  consignmentStock  ConsignmentStock[]
  consignmentVisits ConsignmentVisit[]
  customPrices      CustomPrice[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
}

model Category {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userId    String
  parentId  String?
  bg        String?
  color     String?
  parent    Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToSubcategory")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([name, parentId])
}

model Product {
  id               String            @id @default(uuid())
  productCode      String
  name             String
  description      String?
  unit             String            @default("per project")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String
  unitPrice        Float
  stock            Int               @default(0)
  categoryId       String?
  consignmentItems ConsignmentItem[]
  customPrices     CustomPrice[]
  invoiceItems     InvoiceItem[]
  category         Category?         @relation(fields: [categoryId], references: [id])
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                String             @id @default(uuid())
  invoiceNumber     String             @unique
  purchaseOrder     String?
  status            InvoiceStatus      @default(OUTSTANDING)
  issueDate         DateTime           @default(now())
  dueDate           DateTime
  notes             String?
  subtotal          Float
  tax               Float              @default(0)
  total             Float
  paidAt            DateTime?
  sentAt            DateTime?
  reminderSentAt    DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String
  customerId        String
  isConsignment     Boolean            @default(false)
  consignmentVisits ConsignmentVisit[]
  customer          Customer           @relation(fields: [customerId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  quantity    Int
  unitPrice   Float
  total       Float
  date        DateTime?
  invoiceId   String
  productId   String?
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])
}

model CustomPrice {
  id         String   @id @default(uuid())
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  customerId String
  productId  String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

model ConsignmentVisit {
  id         String            @id @default(uuid())
  date       DateTime          @default(now())
  invoiced   Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  userId     String
  customerId String
  invoiceId  String?
  nextVisit  String?
  notes      String?
  items      ConsignmentItem[]
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice    Invoice?          @relation(fields: [invoiceId], references: [id])
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConsignmentItem {
  id        String           @id @default(uuid())
  name      String
  quantity  Int
  unitPrice Float
  total     Float
  visitId   String
  productId String?
  product   Product?         @relation(fields: [productId], references: [id])
  visit     ConsignmentVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  OUTSTANDING
  PAID
  OVERDUE
  DRAFT
}

model ConsignmentStock {
  id         String   @id @default(uuid())
  code       String
  name       String
  stocked    Int
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, code])
}

